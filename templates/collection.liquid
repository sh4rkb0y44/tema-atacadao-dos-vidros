<section style="padding:40px 0 80px;">
  <div class="container" style="max-width:1200px;margin:0 auto;padding:0 24px;">
    <div style="display:grid;grid-template-columns:1fr 2fr;gap:40px;">
      <div>
        <h1 style="font-size:36px;font-weight:900;letter-spacing:-0.04em;text-transform:uppercase;line-height:1.1;margin-bottom:8px;">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <p style="font-size:16px;color:var(--brand-muted);line-height:1.6;">{{ collection.description }}</p>
        {%- endif -%}
      </div>
      <div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
          {%- for product in collection.products -%}
            {%- render 'product-card', product: product -%}
          {%- endfor -%}
        </div>
        {% if collection.products.size == 0 %}
          <p style="text-align:center;color:var(--brand-muted);padding:60px 0;">Nenhum produto encontrado nesta colecao.</p>
        {% endif %}
        {%- if paginate.pages > 1 -%}
          <div style="display:flex;justify-content:center;gap:8px;margin-top:40px;">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
