<section style="padding:40px 0 80px;">
  <div class="container" style="max-width:1200px;margin:0 auto;padding:0 24px;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;">

      <div>
        {%- if product.featured_image != blank -%}
          <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" style="width:100%;border-radius:var(--radius-lg);">
        {%- else -%}
          <div style="aspect-ratio:1;background:#F1F5F9;border-radius:var(--radius-lg);display:flex;align-items:center;justify-content:center;">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
        {%- if product.images.size > 1 -%}
          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:12px;">
            {%- for image in product.images offset:1 -%}
              <img src="{{ image | image_url: width: 200 }}" alt="" style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:var(--radius);border:1px solid var(--border);cursor:pointer;">
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div>
        <span style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--brand);margin-bottom:8px;display:block;">{{ product.type }}</span>
        <h1 style="font-size:36px;font-weight:900;letter-spacing:-0.04em;margin-bottom:16px;line-height:1.1;">{{ product.title }}</h1>

        <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:24px;">
          {%- if product.compare_at_price > product.price -%}
            <span style="font-size:16px;color:var(--brand-muted);text-decoration:line-through;">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          <strong style="font-size:32px;font-weight:900;letter-spacing:-0.02em;">{{ product.price | money }}</strong>
        </div>

        <div style="font-size:15px;color:var(--brand-muted);line-height:1.7;margin-bottom:32px;">
          {{ product.description }}
        </div>

        {%- form 'product', product -%}
          {%- if product.variants.size > 1 -%}
            <div style="margin-bottom:24px;">
              <label style="font-size:14px;font-weight:700;text-transform:uppercase;margin-bottom:8px;display:block;">Opcoes</label>
              <select name="id" style="width:100%;padding:14px 16px;border:1px solid var(--border);border-radius:10px;font-size:15px;font-family:inherit;background:var(--white);">
                {%- for variant in product.variants -%}
                  <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                    {{ variant.title }} — {{ variant.price | money }}
                    {% unless variant.available %} (Esgotado){% endunless %}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          {%- endif -%}

          <div style="display:flex;gap:12px;margin-bottom:24px;">
            <div style="display:flex;align-items:center;border:1px solid var(--border);border-radius:10px;overflow:hidden;">
              <button type="button" onclick="this.parentElement.querySelector('input').stepDown();this.parentElement.querySelector('input').dispatchEvent(new Event('change'))" style="width:42px;height:42px;border:none;background:none;font-size:18px;cursor:pointer;">-</button>
              <input type="number" name="quantity" value="1" min="1" style="width:50px;text-align:center;border:none;font-size:15px;font-family:inherit;outline:none;">
              <button type="button" onclick="this.parentElement.querySelector('input').stepUp();this.parentElement.querySelector('input').dispatchEvent(new Event('change'))" style="width:42px;height:42px;border:none;background:none;font-size:18px;cursor:pointer;">+</button>
            </div>
            <button type="submit" style="flex:1;padding:14px 28px;background:var(--brand);color:var(--white);font-size:15px;font-weight:700;border-radius:10px;text-transform:uppercase;letter-spacing:0.02em;border:none;cursor:pointer;transition:all var(--transition);" {% unless product.available %}disabled{% endunless %}>
              {%- if product.available -%}
                Adicionar ao Carrinho
              {%- else -%}
                Esgotado
              {%- endif -%}
            </button>
          </div>
        {%- endform -%}

        <div style="border-top:1px solid var(--border);padding-top:24px;display:flex;flex-direction:column;gap:12px;">
          <div style="display:flex;align-items:center;gap:12px;font-size:14px;color:var(--brand-muted);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            Entrega rapida para toda a regiao
          </div>
          <div style="display:flex;align-items:center;gap:12px;font-size:14px;color:var(--brand-muted);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Compra 100% segura
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
