<section style="padding:40px 0 80px;">
  <div class="container" style="max-width:1200px;margin:0 auto;padding:0 24px;">
    <h1 style="font-size:36px;font-weight:900;letter-spacing:-0.04em;text-transform:uppercase;margin-bottom:32px;">{{ blog.title }}</h1>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;text-decoration:none;color:inherit;">
          {%- if article.image -%}
            <img src="{{ article.image | image_url: width: 400, height: 250, crop: 'center' }}" alt="{{ article.title }}" style="width:100%;aspect-ratio:16/10;object-fit:cover;">
          {%- endif -%}
          <div style="padding:24px;">
            <p style="font-size:12px;color:var(--brand-muted);margin-bottom:8px;">{{ article.published_at | date: '%d/%m/%Y' }}</p>
            <h3 style="font-size:18px;font-weight:800;margin-bottom:8px;">{{ article.title }}</h3>
            <p style="font-size:14px;color:var(--brand-muted);line-height:1.5;">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
