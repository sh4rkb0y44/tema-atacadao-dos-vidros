<section class="testimonials-section">
  <div class="container">
    <div class="section-header">
      <div class="section-header-content">
        <span class="section-label">{{ section.settings.subtitle }}</span>
        <h2 class="section-title">{{ section.settings.title }}</h2>
      </div>
    </div>

    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          <div class="testimonial-card" {{ block.shopify_attributes }}>
            <div class="testimonial-stars">
              {%- for i in (1..5) -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="{% if i <= block.settings.rating %}var(--yellow){% else %}#E2E8F0{% endif %}"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- endfor -%}
            </div>
            <p class="testimonial-text">{{ block.settings.text }}</p>
            <div class="testimonial-author">
              <div class="author-avatar">
                {%- if block.settings.avatar != blank -%}
                  <img src="{{ block.settings.avatar | image_url: width: 48 }}" alt="{{ block.settings.name }}">
                {%- else -%}
                  <div class="avatar-placeholder">{{ block.settings.name | slice: 0 }}</div>
                {%- endif -%}
              </div>
              <div class="author-info">
                <strong class="author-name">{{ block.settings.name }}</strong>
                <span class="author-location">{{ block.settings.location }}</span>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.testimonials-section {
  padding: 80px 0;
  background: linear-gradient(180deg, var(--brand-bg) 0%, var(--white) 100%);
}

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}

.testimonial-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 32px;
  transition: all 0.3s;
  display: flex;
  flex-direction: column;
}

.testimonial-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-xl);
  border-color: var(--brand);
}

.testimonial-stars {
  display: flex;
  gap: 4px;
  margin-bottom: 20px;
}

.testimonial-text {
  font-size: 15px;
  color: var(--brand-dark);
  line-height: 1.7;
  margin-bottom: 24px;
  flex: 1;
  font-style: italic;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 14px;
  padding-top: 20px;
  border-top: 1px solid var(--border);
}

.author-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.author-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--brand) 0%, var(--brand-deep) 100%);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 800;
}

.author-info {
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 15px;
  font-weight: 700;
  color: var(--brand-dark);
  margin-bottom: 2px;
}

.author-location {
  font-size: 13px;
  color: var(--brand-muted);
}

@media (max-width: 1024px) {
  .testimonials-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .testimonials-section {
    padding: 48px 0;
  }
  
  .testimonials-grid {
    grid-template-columns: 1fr;
  }
  
  .testimonial-card {
    padding: 24px;
  }
}
</style>

{% schema %}
{
  "name": "Depoimentos",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Depoimentos"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "O que nossos clientes dizem"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Depoimento",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Foto do cliente"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nome",
          "default": "Cliente"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Localizacao",
          "default": "Sao Paulo, SP"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Avaliacao",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto do depoimento",
          "default": "Otimo atendimento e produtos de qualidade. Recomendo!"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Depoimentos",
      "blocks": [
        { "type": "testimonial", "settings": { "name": "Carlos Silva", "location": "Sao Paulo, SP", "rating": 5, "text": "Melhor loja de vidros da regiao. Preco justo e entrega rapida. Ja comprei varias vezes e sempre fui bem atendido." } },
        { "type": "testimonial", "settings": { "name": "Ana Santos", "location": "Campinas, SP", "rating": 5, "text": "Box do banheiro ficou perfeito! Instalacao profissional e material de otima qualidade. Super recomendo." } },
        { "type": "testimonial", "settings": { "name": "Roberto Lima", "location": "Sorocaba, SP", "rating": 5, "text": "Comprei vidros temperados para minha obra. Preco de atacado mesmo e qualidade excelente. Voltarei a comprar." } }
      ]
    }
  ]
}
{% endschema %}
