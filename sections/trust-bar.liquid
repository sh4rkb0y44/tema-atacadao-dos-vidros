<section class="trust-section">
  <div class="container">
    <div class="trust-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust_item' -%}
          <div class="trust-item" {{ block.shopify_attributes }}>
            <div class="trust-icon">
              {%- if block.settings.icon != blank -%}
                <img src="{{ block.settings.icon | image_url: width: 44 }}" alt="">
              {%- else -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- endif -%}
            </div>
            <div class="trust-content">
              <h4 class="trust-title">{{ block.settings.title }}</h4>
              <p class="trust-description">{{ block.settings.description }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.trust-section {
  padding: 60px 0;
  background: var(--white);
}

.trust-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

.trust-item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 28px 24px;
  background: var(--brand-bg);
  border-radius: 16px;
  transition: all 0.3s;
  border: 1px solid transparent;
}

.trust-item:hover {
  background: var(--white);
  border-color: var(--border);
  box-shadow: var(--shadow-md);
  transform: translateY(-4px);
}

.trust-icon {
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(59, 130, 246, 0.05) 100%);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s;
}

.trust-icon svg {
  color: var(--brand);
}

.trust-icon img {
  width: 24px;
  height: 24px;
  object-fit: contain;
}

.trust-item:hover .trust-icon {
  background: linear-gradient(135deg, var(--brand) 0%, var(--brand-deep) 100%);
}

.trust-item:hover .trust-icon svg {
  color: var(--white);
}

.trust-content {
  flex: 1;
}

.trust-title {
  font-size: 15px;
  font-weight: 800;
  text-transform: uppercase;
  margin-bottom: 6px;
  color: var(--brand-dark);
  letter-spacing: -0.01em;
}

.trust-description {
  font-size: 13px;
  color: var(--brand-muted);
  line-height: 1.5;
}

@media (max-width: 1024px) {
  .trust-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .trust-section {
    padding: 40px 0;
  }
  
  .trust-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  
  .trust-item {
    padding: 20px;
  }
}
</style>

{% schema %}
{
  "name": "Barra de Confianca",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Item de Confianca",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icone"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titulo",
          "default": "Compra Segura"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descricao",
          "default": "Site protegido com certificado SSL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barra de Confianca",
      "blocks": [
        { "type": "trust_item", "settings": { "title": "Compra Segura", "description": "Site protegido com certificado SSL e dados criptografados" } },
        { "type": "trust_item", "settings": { "title": "Entrega Rapida", "description": "Enviamos para todo o Brasil com rastreamento" } },
        { "type": "trust_item", "settings": { "title": "Suporte Especializado", "description": "Equipe tecnica pronta para ajudar" } },
        { "type": "trust_item", "settings": { "title": "12x Sem Juros", "description": "Parcele suas compras no cartao" } }
      ]
    }
  ]
}
{% endschema %}
