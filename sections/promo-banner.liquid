<section style="padding:0 0 80px;">
  <div class="container" style="max-width:1200px;margin:0 auto;padding:0 24px;">
    <div style="background:linear-gradient(135deg,var(--brand) 0%,var(--brand-deep) 100%);border-radius:var(--radius-lg);padding:60px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;position:relative;overflow:hidden;">

      <div style="position:relative;z-index:1;">
        <h2 style="font-size:40px;font-weight:900;color:var(--white);letter-spacing:-0.04em;text-transform:uppercase;line-height:1.05;margin-bottom:16px;">{{ section.settings.title }}</h2>
        {%- if section.settings.description != blank -%}
          <p style="font-size:16px;color:rgba(255,255,255,0.7);margin-bottom:28px;line-height:1.6;">{{ section.settings.description }}</p>
        {%- endif -%}
        {%- if section.settings.btn_text != blank -%}
          <a href="{{ section.settings.btn_link }}" style="display:inline-flex;align-items:center;gap:8px;background:var(--white);color:var(--brand);font-size:15px;font-weight:700;padding:14px 28px;border-radius:10px;text-transform:uppercase;letter-spacing:0.02em;text-decoration:none;">
            {{ section.settings.btn_text }}
          </a>
        {%- endif -%}
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;position:relative;z-index:1;">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <div style="background:rgba(255,255,255,0.1);border-radius:var(--radius);padding:20px;" {{ block.shopify_attributes }}>
              <strong style="display:block;font-size:24px;font-weight:900;color:var(--white);margin-bottom:4px;">{{ block.value }}</strong>
              <span style="font-size:12px;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;">{{ block.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Banner Promocional",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Orcamento para Grandes Projetos"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descricao",
      "default": "Precisa de vidros sob medida para sua obra? Faca seu orcamento com condicoes especiais para atacado e projetos de grande porte."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Texto do botao",
      "default": "Solicitar Orcamento"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Link do botao",
      "default": "/pages/orcamento"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Destaque",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Valor",
          "default": "30%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Rotulo",
          "default": "Desconto no atacado"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Promocional",
      "blocks": [
        { "type": "feature", "settings": { "value": "30%", "label": "Desconto no atacado" } },
        { "type": "feature", "settings": { "value": "48h", "label": "Orcamento rapido" } },
        { "type": "feature", "settings": { "value": "Sob Medida", "label": "Corte personalizado" } },
        { "type": "feature", "settings": { "value": "Frete", "label": "Entrega programada" } }
      ]
    }
  ]
}
{% endschema %}
