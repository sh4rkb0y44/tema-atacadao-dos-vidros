<section class="hero-section">
  <div class="hero-container">
    <div class="hero-content">
      {%- if section.settings.badge != blank -%}
        <div class="hero-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          {{ section.settings.badge }}
        </div>
      {%- endif -%}

      <h1 class="hero-title">
        {{ section.settings.title }}
      </h1>

      {%- if section.settings.description != blank -%}
        <p class="hero-description">
          {{ section.settings.description }}
        </p>
      {%- endif -%}

      <div class="hero-ctas">
        {%- if section.settings.btn_primary_text != blank -%}
          <a href="{{ section.settings.btn_primary_link }}" class="btn-primary">
            {{ section.settings.btn_primary_text }}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.btn_secondary_text != blank -%}
          <a href="{{ section.settings.btn_secondary_link }}" class="btn-secondary">
            {{ section.settings.btn_secondary_text }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_stats -%}
        <div class="hero-stats">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              <div class="hero-stat" {{ block.shopify_attributes }}>
                <strong class="stat-value">{{ block.settings.value }}</strong>
                <span class="stat-label">{{ block.settings.label }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="hero-visual">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.title }}" class="hero-image">
      {%- else -%}
        <div class="hero-prism">
          <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="prismGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="var(--brand-light)" stop-opacity="0.3"/>
                <stop offset="100%" stop-color="var(--brand)" stop-opacity="0.1"/>
              </linearGradient>
              <filter id="glow">
                <feGaussianBlur stdDeviation="20" result="coloredBlur"/>
                <feMerge>
                  <feMergeNode in="coloredBlur"/>
                  <feMergeNode in="SourceGraphic"/>
                </feMerge>
              </filter>
            </defs>
            
            <circle cx="200" cy="200" r="180" fill="url(#prismGradient)" filter="url(#glow)"/>
            
            <g transform="translate(120, 100)">
              <polygon points="40,60 100,30 100,130 40,160" fill="var(--brand)" opacity="0.9"/>
              <polygon points="100,30 160,60 160,160 100,130" fill="var(--brand-deep)"/>
              <polygon points="40,60 100,30 160,60 100,90" fill="var(--brand-light)"/>
            </g>
            
            <circle cx="200" cy="80" r="6" fill="var(--brand-light)" opacity="0.6"/>
            <circle cx="140" cy="140" r="4" fill="var(--brand-light)" opacity="0.4"/>
            <circle cx="260" cy="140" r="4" fill="var(--brand-light)" opacity="0.4"/>
            <circle cx="200" cy="260" r="5" fill="var(--brand)" opacity="0.5"/>
          </svg>
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="hero-features">
    <div class="container">
      <div class="hero-features-grid">
        <div class="hero-feature">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <div>
            <strong>Compra Segura</strong>
            <span>Site 100% protegido</span>
          </div>
        </div>
        <div class="hero-feature">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <div>
            <strong>Entrega Rapida</strong>
            <span>Para todo o Brasil</span>
          </div>
        </div>
        <div class="hero-feature">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          <div>
            <strong>12x Sem Juros</strong>
            <span>No cartao de credito</span>
          </div>
        </div>
        <div class="hero-feature">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <div>
            <strong>Suporte 24/7</strong>
            <span>Atendimento especializado</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero-section {
  background: linear-gradient(135deg, var(--brand-dark) 0%, #1E293B 50%, var(--brand-deep) 100%);
  padding: 80px 0 0;
  position: relative;
  overflow: hidden;
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 800px;
  height: 800px;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
  pointer-events: none;
}

.hero-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(37, 99, 235, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

.hero-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(250, 204, 21, 0.15);
  border: 1px solid rgba(250, 204, 21, 0.3);
  border-radius: 100px;
  padding: 8px 20px;
  font-size: 13px;
  font-weight: 700;
  color: var(--yellow);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 28px;
}

.hero-title {
  font-size: 56px;
  font-weight: 900;
  color: var(--white);
  letter-spacing: -0.03em;
  line-height: 1.05;
  text-transform: uppercase;
  margin-bottom: 24px;
  font-family: var(--font-display);
}

.hero-title em {
  font-style: normal;
  color: var(--brand-light);
  position: relative;
}

.hero-description {
  font-size: 18px;
  color: #94A3B8;
  line-height: 1.7;
  margin-bottom: 40px;
  max-width: 520px;
}

.hero-ctas {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 48px;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--brand);
  color: var(--white);
  font-size: 16px;
  font-weight: 700;
  padding: 16px 32px;
  border-radius: 12px;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  transition: all 0.3s;
  box-shadow: 0 8px 24px rgba(37, 99, 235, 0.3);
}

.btn-primary:hover {
  background: var(--brand-deep);
  transform: translateY(-2px);
  box-shadow: 0 12px 32px rgba(37, 99, 235, 0.4);
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: transparent;
  color: var(--white);
  font-size: 16px;
  font-weight: 700;
  padding: 16px 32px;
  border-radius: 12px;
  border: 2px solid rgba(255, 255, 255, 0.2);
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  transition: all 0.3s;
}

.btn-secondary:hover {
  border-color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.05);
}

.hero-stats {
  display: flex;
  gap: 48px;
  padding-top: 32px;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.hero-stat {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 32px;
  font-weight: 900;
  color: var(--white);
  letter-spacing: -0.02em;
  margin-bottom: 4px;
}

.stat-label {
  font-size: 13px;
  color: #64748B;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-weight: 600;
}

.hero-visual {
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero-image {
  max-width: 100%;
  height: auto;
  border-radius: 20px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}

.hero-prism {
  width: 400px;
  height: 400px;
  position: relative;
}

.hero-prism svg {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 20px 60px rgba(37, 99, 235, 0.4));
}

.hero-features {
  background: var(--white);
  border-radius: 20px 20px 0 0;
  margin-top: 60px;
  padding: 40px 0;
  position: relative;
  z-index: 2;
}

.hero-features-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
}

.hero-feature {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 20px;
  background: var(--brand-bg);
  border-radius: 12px;
  transition: all 0.3s;
}

.hero-feature:hover {
  background: var(--white);
  box-shadow: var(--shadow-md);
  transform: translateY(-4px);
}

.hero-feature svg {
  color: var(--brand);
  flex-shrink: 0;
}

.hero-feature div {
  display: flex;
  flex-direction: column;
}

.hero-feature strong {
  font-size: 14px;
  font-weight: 800;
  color: var(--brand-dark);
  text-transform: uppercase;
  margin-bottom: 2px;
}

.hero-feature span {
  font-size: 12px;
  color: var(--brand-muted);
}

@media (max-width: 1024px) {
  .hero-container {
    grid-template-columns: 1fr;
    gap: 48px;
  }
  
  .hero-title {
    font-size: 44px;
  }
  
  .hero-features-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .hero-section {
    padding: 48px 0 0;
  }
  
  .hero-title {
    font-size: 32px;
  }
  
  .hero-description {
    font-size: 16px;
  }
  
  .hero-stats {
    gap: 24px;
    flex-wrap: wrap;
  }
  
  .stat-value {
    font-size: 24px;
  }
  
  .hero-prism {
    width: 280px;
    height: 280px;
  }
  
  .hero-features-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  
  .hero-ctas {
    flex-direction: column;
  }
  
  .btn-primary,
  .btn-secondary {
    width: 100%;
    justify-content: center;
  }
}
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Novidade na loja"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Titulo principal",
      "default": "<p>Vidros e Espelhos com <em>Preco de Atacado</em></p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descricao",
      "default": "Materiais de alta qualidade para sua obra ou projeto. Compre direto do fabricante com entrega rapida e segura em toda a regiao."
    },
    {
      "type": "text",
      "id": "btn_primary_text",
      "label": "Texto botao principal",
      "default": "Ver Produtos"
    },
    {
      "type": "url",
      "id": "btn_primary_link",
      "label": "Link botao principal"
    },
    {
      "type": "text",
      "id": "btn_secondary_text",
      "label": "Texto botao secundario",
      "default": "Solicitar Orcamento"
    },
    {
      "type": "url",
      "id": "btn_secondary_link",
      "label": "Link botao secundario"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagem do hero"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Mostrar estatisticas",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Estatistica",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Valor",
          "default": "2.500+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Rotulo",
          "default": "Produtos"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "stat", "settings": { "value": "2.500+", "label": "Produtos" } },
        { "type": "stat", "settings": { "value": "15 anos", "label": "De mercado" } },
        { "type": "stat", "settings": { "value": "4.9", "label": "Avaliacao" } }
      ]
    }
  ]
}
{% endschema %}
