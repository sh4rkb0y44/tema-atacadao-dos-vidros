<footer class="footer">
  <div class="container">
    <div class="footer-main">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          {%- if settings.logo != blank -%}
            <img src="{{ settings.logo | image_url: width: 120 }}" alt="{{ shop.name }}">
          {%- else -%}
            <div class="footer-logo-icon">
              <svg width="28" height="28" viewBox="0 0 100 100" fill="none">
                <polygon points="20,25 50,15 50,65 20,75" fill="var(--brand)" opacity="0.9"/>
                <polygon points="50,15 80,25 80,75 50,65" fill="var(--brand-deep)"/>
                <polygon points="20,25 50,15 80,25 50,35" fill="var(--brand-light)"/>
              </svg>
            </div>
            <div class="footer-logo-text">
              <strong>{{ shop.name }}</strong>
            </div>
          {%- endif -%}
        </a>
        {%- if section.settings.description != blank -%}
          <p class="footer-description">{{ section.settings.description }}</p>
        {%- endif -%}
        
        <div class="footer-social">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" class="social-link" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" class="social-link" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_whatsapp != blank -%}
            <a href="https://wa.me/{{ settings.social_whatsapp }}" class="social-link" aria-label="WhatsApp" target="_blank">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="footer-column" {{ block.shopify_attributes }}>
            <h5 class="footer-heading">{{ block.settings.heading }}</h5>
            <ul class="footer-links">
              {%- for link in linklists[block.settings.menu].links -%}
                <li>
                  <a href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <div class="footer-column">
        <h5 class="footer-heading">Contato</h5>
        <ul class="footer-contact">
          {%- if section.settings.phone != blank -%}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {{ section.settings.phone }}
            </li>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              {{ section.settings.email }}
            </li>
          {%- endif -%}
          {%- if section.settings.address != blank -%}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {{ section.settings.address }}
            </li>
          {%- endif -%}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-copyright">
        <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos os direitos reservados.</span>
      </div>
      <div class="footer-payments">
        <span class="payment-label">Formas de pagamento:</span>
        <div class="payment-methods">
          {%- for type in shop.enabled_payment_types -%}
            <span class="payment-icon">{{ type | payment_type_svg_tag }}</span>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--white);
  border-top: 1px solid var(--border);
  padding: 64px 0 32px;
}

.footer-main {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;
  gap: 48px;
  margin-bottom: 48px;
}

.footer-brand {
  display: flex;
  flex-direction: column;
}

.footer-logo {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
  color: inherit;
  margin-bottom: 20px;
}

.footer-logo-icon {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, var(--brand) 0%, var(--brand-deep) 100%);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-logo-text strong {
  font-size: 18px;
  font-weight: 900;
  letter-spacing: -0.02em;
  color: var(--brand-dark);
}

.footer-description {
  font-size: 14px;
  color: var(--brand-muted);
  line-height: 1.7;
  margin-bottom: 24px;
  max-width: 280px;
}

.footer-social {
  display: flex;
  gap: 12px;
}

.social-link {
  width: 40px;
  height: 40px;
  background: var(--brand-bg);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--brand-muted);
  text-decoration: none;
  transition: all 0.3s;
}

.social-link:hover {
  background: var(--brand);
  color: var(--white);
  transform: translateY(-2px);
}

.footer-column {
  display: flex;
  flex-direction: column;
}

.footer-heading {
  font-size: 13px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--brand-dark);
  margin-bottom: 20px;
}

.footer-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.footer-links a {
  font-size: 14px;
  color: var(--brand-muted);
  text-decoration: none;
  transition: color 0.2s;
}

.footer-links a:hover {
  color: var(--brand);
}

.footer-contact {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.footer-contact li {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: var(--brand-muted);
}

.footer-contact svg {
  color: var(--brand);
  flex-shrink: 0;
}

.footer-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 32px;
  border-top: 1px solid var(--border);
  flex-wrap: wrap;
  gap: 20px;
}

.footer-copyright {
  font-size: 13px;
  color: var(--brand-muted);
}

.footer-payments {
  display: flex;
  align-items: center;
  gap: 16px;
}

.payment-label {
  font-size: 13px;
  color: var(--brand-muted);
  font-weight: 600;
}

.payment-methods {
  display: flex;
  gap: 8px;
}

.payment-icon {
  background: var(--brand-bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 6px 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.payment-icon svg {
  width: 24px;
  height: 16px;
}

@media (max-width: 1024px) {
  .footer-main {
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  
  .footer-brand {
    grid-column: 1 / -1;
  }
}

@media (max-width: 768px) {
  .footer {
    padding: 48px 0 24px;
  }
  
  .footer-main {
    grid-template-columns: 1fr;
    gap: 32px;
  }
  
  .footer-bottom {
    flex-direction: column;
    text-align: center;
  }
  
  .footer-payments {
    flex-direction: column;
    gap: 12px;
  }
}
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "description",
      "label": "Descricao da loja",
      "default": "Sua loja de vidros, espelhos e acessorios com preco de atacado. Qualidade e confianca ha mais de 15 anos no mercado."
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Telefone",
      "default": "(11) 4000-0000"
    },
    {
      "type": "text",
      "id": "email",
      "label": "E-mail",
      "default": "contato@atacadaodosvidros.com.br"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Endereco",
      "default": "Sao Paulo, SP"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Lista de Links",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titulo",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list", "settings": { "heading": "Produtos", "menu": "footer-products" } },
      { "type": "link_list", "settings": { "heading": "Institucional", "menu": "footer-institutional" } },
      { "type": "link_list", "settings": { "heading": "Atendimento", "menu": "footer-support" } }
    ]
  }
}
{% endschema %}
