<section style="padding:80px 0;">
  <div class="container" style="max-width:1200px;margin:0 auto;padding:0 24px;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:40px;gap:20px;">
      <div>
        <span style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:var(--brand);margin-bottom:8px;display:block;">{{ section.settings.subtitle }}</span>
        <h2 style="font-size:36px;font-weight:900;letter-spacing:-0.04em;text-transform:uppercase;line-height:1.1;">{{ section.settings.title }}</h2>
      </div>
      {%- if section.settings.link_text != blank -%}
        <a href="{{ section.settings.link }}" style="font-size:14px;font-weight:700;color:var(--brand);display:flex;align-items:center;gap:6px;text-decoration:none;">
          {{ section.settings.link_text }} &rarr;
        </a>
      {%- endif -%}
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:32px 24px;text-align:center;transition:all var(--transition);text-decoration:none;color:inherit;" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div style="width:72px;height:72px;margin:0 auto 20px;background:var(--brand-bg);border-radius:16px;display:flex;align-items:center;justify-content:center;">
              <img src="{{ block.settings.icon | image_url: width: 64 }}" alt="" style="width:32px;height:32px;">
            </div>
          {%- else -%}
            <div style="width:72px;height:72px;margin:0 auto 20px;background:var(--brand-bg);border-radius:16px;display:flex;align-items:center;justify-content:center;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
            </div>
          {%- endif -%}
          <h3 style="font-size:16px;font-weight:800;text-transform:uppercase;letter-spacing:-0.02em;margin-bottom:6px;">{{ block.settings.title }}</h3>
          <p style="font-size:13px;color:var(--brand-muted);">{{ block.settings.description }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Categorias",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Navegue por"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Categorias"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Texto do link",
      "default": "Ver todas"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoria",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icone"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titulo",
          "default": "Categoria"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descricao",
          "default": "Descricao curta"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categorias",
      "blocks": [
        { "type": "category", "settings": { "title": "Vidros Temperados", "description": "Seguranca e resistencia", "link": "/collections/vidros-temperados" } },
        { "type": "category", "settings": { "title": "Espelhos", "description": "Diversos tamanhos", "link": "/collections/espelhos" } },
        { "type": "category", "settings": { "title": "Box para Banheiro", "description": "Sob medida", "link": "/collections/box-banheiro" } },
        { "type": "category", "settings": { "title": "Acessorios", "description": "Ferragens e perfis", "link": "/collections/acessorios" } }
      ]
    }
  ]
}
{% endschema %}
