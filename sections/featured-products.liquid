<section class="products-section">
  <div class="container">
    <div class="section-header">
      <div class="section-header-content">
        <span class="section-label">{{ section.settings.subtitle }}</span>
        <h2 class="section-title">{{ section.settings.title }}</h2>
      </div>
      {%- if section.settings.link_text != blank -%}
        <a href="{{ section.settings.link }}" class="section-link">
          {{ section.settings.link_text }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="products-grid">
      {%- assign product_limit = section.settings.products_to_show | default: 8 -%}
      {%- assign selected_collection = section.settings.collection -%}
      {%- if selected_collection == blank -%}
        {%- assign selected_collection = collections.all -%}
      {%- endif -%}
      {%- assign displayed = 0 -%}
      {%- for product in selected_collection.products -%}
        {%- if displayed < product_limit and product.featured_image != blank -%}
          {%- assign displayed = displayed | plus: 1 -%}
          {%- render 'product-card', product: product -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if displayed == 0 -%}
        {%- for product in collections.all.products -%}
          {%- if displayed < product_limit and product.featured_image != blank -%}
            {%- assign displayed = displayed | plus: 1 -%}
            {%- render 'product-card', product: product -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
.products-section {
  padding: 80px 0;
  background: var(--white);
}

.products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

.product-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 20px;
  overflow: hidden;
  transition: all 0.3s;
  display: flex;
  flex-direction: column;
}

.product-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-xl);
  border-color: var(--brand);
}

.product-image {
  aspect-ratio: 1;
  background: linear-gradient(135deg, #F1F5F9 0%, #E2E8F0 100%);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.product-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s;
}

.product-card:hover .product-image img {
  transform: scale(1.08);
}

.product-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--yellow);
  color: var(--brand-dark);
  font-size: 11px;
  font-weight: 800;
  padding: 6px 12px;
  border-radius: 8px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  box-shadow: 0 4px 12px rgba(250, 204, 21, 0.3);
}

.product-info {
  padding: 24px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.product-category {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--brand);
  margin-bottom: 8px;
}

.product-name {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 8px;
  letter-spacing: -0.01em;
  line-height: 1.3;
  color: var(--brand-dark);
}

.product-description {
  font-size: 13px;
  color: var(--brand-muted);
  margin-bottom: 20px;
  line-height: 1.5;
  flex: 1;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.product-price {
  display: flex;
  flex-direction: column;
}

.product-price small {
  font-size: 12px;
  color: var(--brand-muted);
  text-decoration: line-through;
  margin-bottom: 2px;
}

.product-price strong {
  font-size: 22px;
  font-weight: 900;
  letter-spacing: -0.02em;
  color: var(--brand-dark);
}

.product-price strong span {
  font-size: 13px;
  font-weight: 600;
  color: var(--brand-muted);
}

.add-cart-btn {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: var(--brand);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  cursor: pointer;
  transition: all 0.3s;
  flex-shrink: 0;
}

.add-cart-btn:hover {
  background: var(--brand-deep);
  transform: scale(1.1);
  box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
}

@media (max-width: 1024px) {
  .products-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .section-title {
    font-size: 32px;
  }
}

@media (max-width: 768px) {
  .products-section {
    padding: 48px 0;
  }
  
  .products-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  
  .product-info {
    padding: 16px;
  }
  
  .product-name {
    font-size: 14px;
  }
  
  .product-price strong {
    font-size: 18px;
  }
}
</style>

{% schema %}
{
  "name": "Produtos em Destaque",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Mais vendidos"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Produtos em Destaque"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colecao"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Produtos a exibir",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 8
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Texto do link",
      "default": "Ver todos"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Produtos em Destaque"
    }
  ]
}
{% endschema %}
