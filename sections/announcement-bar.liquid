{%- if section.settings.show_announcement -%}
<div class="announcement-bar">
  <div class="container">
    <div class="announcement-content">
      <div class="announcement-text">
        {{ section.settings.announcement_text }}
      </div>
      <div class="announcement-actions">
        {%- if section.settings.show_phone -%}
          <a href="tel:{{ section.settings.phone_number }}" class="announcement-phone">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {{ section.settings.phone_number }}
          </a>
        {%- endif -%}
        {%- if section.settings.show_whatsapp -%}
          <a href="https://wa.me/{{ section.settings.whatsapp_number }}" class="announcement-whatsapp" target="_blank">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
.announcement-bar {
  background: linear-gradient(90deg, var(--brand-dark) 0%, #1E293B 100%);
  color: var(--white);
  padding: 10px 0;
  font-size: 13px;
  font-weight: 500;
}

.announcement-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.announcement-text {
  flex: 1;
  text-align: center;
}

.announcement-text strong {
  color: var(--yellow);
  font-weight: 700;
}

.announcement-actions {
  display: flex;
  gap: 16px;
  align-items: center;
}

.announcement-phone,
.announcement-whatsapp {
  display: flex;
  align-items: center;
  gap: 6px;
  color: var(--white);
  text-decoration: none;
  font-weight: 600;
  transition: opacity 0.2s;
}

.announcement-phone:hover,
.announcement-whatsapp:hover {
  opacity: 0.8;
}

.announcement-whatsapp {
  background: #25D366;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
}

@media (max-width: 768px) {
  .announcement-content {
    flex-direction: column;
    gap: 8px;
  }
  
  .announcement-actions {
    font-size: 11px;
  }
}
</style>

{% schema %}
{
  "name": "Barra de Anuncio",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Mostrar barra",
      "default": true
    },
    {
      "type": "richtext",
      "id": "announcement_text",
      "label": "Texto",
      "default": "<p>Frete gratis para compras acima de <strong>R$ 499</strong> — Parcele em ate <strong>12x sem juros</strong></p>"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Mostrar telefone",
      "default": true
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Numero de telefone",
      "default": "(11) 4000-0000"
    },
    {
      "type": "checkbox",
      "id": "show_whatsapp",
      "label": "Mostrar WhatsApp",
      "default": true
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "Numero WhatsApp (com DDI)",
      "default": "5511999999999"
    }
  ]
}
{% endschema %}
