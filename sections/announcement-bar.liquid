{%- if section.settings.show_announcement -%}
<div class="announcement-bar">
  <div class="container">
    <div class="announcement-content">
      <div class="announcement-text">
        {{ section.settings.announcement_text }}
      </div>
    </div>
  </div>
</div>

<style>
.announcement-bar {
  background: linear-gradient(90deg, var(--brand-dark) 0%, #1E293B 100%);
  color: var(--white);
  padding: 10px 0;
  font-size: 13px;
  font-weight: 500;
}

.announcement-content {
  text-align: center;
}

.announcement-text strong {
  color: var(--yellow);
  font-weight: 700;
}
</style>
{% endif %}

{% schema %}
{
  "name": "Barra de Anuncio",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Mostrar barra",
      "default": true
    },
    {
      "type": "richtext",
      "id": "announcement_text",
      "label": "Texto",
      "default": "<p>Frete gratis para compras acima de <strong>R$ 499</strong> — Parcele em ate <strong>12x sem juros</strong></p>"
    }
  ]
}
{% endschema %}
